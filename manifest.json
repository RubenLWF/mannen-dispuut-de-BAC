{
  "manifest_version": 2,
  "name": "Mannen Dispuut de BAC",
  "version": "1.0",
  "description": "Makes it so the BAC appears correctly on the GEWIS website.",
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://gewis.nl/nl/association/committees*",
        "https://gewis.nl/en/association/committees*",
        "https://gewis.nl/nl/association/fraternities*",
        "https://gewis.nl/en/association/fraternities*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
